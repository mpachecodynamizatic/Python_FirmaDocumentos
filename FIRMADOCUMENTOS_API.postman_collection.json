		{
			"name": "Firma Digital",
			"item": [
				{
					"name": "Firmar Documento PDF",
					"request": {
						"auth": {
							"type": "apikey",
							"apikey": [
								{
									"key": "value",
									"value": "{{api_key}}",
									"type": "string"
								},
								{
									"key": "key",
									"value": "X-API-Key",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"document_base64\": \"\",\n    \"format\": \"pdf\",\n    \"certificate_base64\": \"<TU_CERTIFICADO_P12_EN_BASE64>\",\n    \"certificate_password\": \"<CONTRASEÑA_DEL_CERTIFICADO>\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/sign",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"sign"
							]
						},
						"description": "Firma un documento PDF con un certificado PKCS#12.\n\n**Campos requeridos:**\n- `document_base64`: Documento PDF en Base64\n- `format`: \"pdf\"\n- `certificate_base64`: Certificado .p12/.pfx en Base64\n- `certificate_password`: Contraseña del certificado\n\n**Autenticación:** Requiere header X-API-Key"
					},
					"response": []
				},
				{
					"name": "Firmar Documento XML",
					"request": {
						"auth": {
							"type": "apikey",
							"apikey": [
								{
									"key": "value",
									"value": "{{api_key}}",
									"type": "string"
								},
								{
									"key": "key",
									"value": "X-API-Key",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"document_base64\": \"PD94bWwgdmVyc2lvbj0iMS4wIiBlbmNvZGluZz0iVVRGLTgiPz4KPGRvY3VtZW50bz4KICAgIDx0aXR1bG8+RG9jdW1lbnRvIGRlIFBydWViYTwvdGl0dWxvPgogICAgPGNvbnRlbmlkbz5Fc3RlIGVzIHVuIGRvY3VtZW50byBYTUwgZGUgcHJ1ZWJhPC9jb250ZW5pZG8+CjwvZG9jdW1lbnRvPg==\",\n    \"format\": \"xml\",\n    \"certificate_base64\": \"<TU_CERTIFICADO_P12_EN_BASE64>\",\n    \"certificate_password\": \"<CONTRASEÑA_DEL_CERTIFICADO>\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/sign",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"sign"
							]
						},
						"description": "Firma un documento XML con un certificado PKCS#12.\n\n**Campos requeridos:**\n- `document_base64`: Documento XML en Base64\n- `format`: \"xml\"\n- `certificate_base64`: Certificado .p12/.pfx en Base64\n- `certificate_password`: Contraseña del certificado\n\n**Autenticación:** Requiere header X-API-Key"
					},
					"response": []
				}
			],
			"description": "Endpoints protegidos para firmar documentos PDF y XML."
