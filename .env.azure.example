# Configuración para despliegue en Azure
# Copia este archivo a .env.azure y completa con tus valores

RESOURCE_GROUP=rg-firmadocumentos
LOCATION=westeurope
APP_SERVICE_PLAN=plan-firmadocumentos
WEBAPP_NAME=dyna-firmadocumentos-api
PYTHON_VERSION=PYTHON:3.11
SKU=B1

# API Key para autenticación (genera una única)
SIGNING_API_KEY=your-secret-api-key-here
